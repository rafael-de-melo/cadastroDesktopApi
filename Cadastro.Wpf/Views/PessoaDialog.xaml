<Window x:Class="Cadastro.Wpf.Views.PessoaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro" Height="320" Width="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="ToolWindow" Background="#FAFAFA">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cadastro de Pessoa" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="Nome" FontWeight="SemiBold" />
            <TextBox x:Name="NomeBox" Height="34" Padding="8" Margin="0,4,0,8"/>

            <TextBlock Text="Sobrenome" FontWeight="SemiBold" Margin="0,8,0,0"/>
            <TextBox x:Name="SobrenomeBox" Height="34" Padding="8" Margin="0,4,0,8"/>

            <TextBlock Text="Telefone" FontWeight="SemiBold" Margin="0,8,0,0"/>
            <TextBox x:Name="TelefoneBox" Height="34" Padding="8" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Width="88" Click="Cancelar_Click" Margin="0,0,8,0"/>
            <Button Content="Salvar" Width="88" Background="#1E88E5" Foreground="White" Click="Salvar_Click"/>
        </StackPanel>
    </Grid>
</Window>
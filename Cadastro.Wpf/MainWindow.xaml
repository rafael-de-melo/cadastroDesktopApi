<Window x:Class="Cadastro.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Pessoas" Height="600" Width="900"
        Background="#FFF7F8FA" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Cadastro de Pessoas" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#111"/>
            <Button Grid.Column="1" Content="+ Novo Cadastro" Padding="10,6" Margin="10,0,0,0"
                    Background="#1E88E5" Foreground="White" BorderThickness="0" Click="OnNovoCadastro_Click"/>
        </Grid>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Border Background="White" BorderBrush="#E6E6E6" BorderThickness="1" CornerRadius="8">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="36" Padding="10"
                         BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                         ToolTip="Pesquisar por nome..." />
            </Border>
        </Grid>

        <!-- List -->
        <ListView Grid.Row="2" ItemsSource="{Binding PessoasView}" Background="Transparent" BorderThickness="0" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <StackPanel>
                                    <TextBlock Text="{Binding Nome}" FontWeight="SemiBold" FontSize="14" Foreground="#222"/>
                                    <TextBlock Text="{Binding Sobrenome}" FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Telefone}" FontSize="13" Foreground="#444" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Width="36" Height="36" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="⋮" FontSize="18" Foreground="#666"/>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Editar" Tag="{Binding}" Click="OnEditar_Click"/>
                                        <MenuItem Header="Excluir" Tag="{Binding}" Click="OnExcluir_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Window>